# ============================================================
#  Configuration de l'envoi d'emails (formulaire de contact)
#  Copiez ce fichier en `.env` et remplissez vos identifiants.
# ============================================================

# Serveur SMTP OVH (messagerie du domaine doubledtech.fr)
SMTP_HOST=ssl0.ovh.net
SMTP_PORT=465
SMTP_SECURE=true            # true pour le port 465 (SSL), false pour 587 (STARTTLS)
SMTP_USER=ddelaunay@doubledtech.fr
SMTP_PASS=votre-mot-de-passe-de-boite-mail

# Adresse qui RECEVRA les demandes (votre boîte pro)
CONTACT_TO=ddelaunay@doubledtech.fr

# Expéditeur affiché (optionnel — par défaut = SMTP_USER)
CONTACT_FROM="Double D Tech — Site <ddelaunay@doubledtech.fr>"

# Adresse email affichée publiquement sur le site (bloc contact + footer)
PUBLIC_CONTACT_EMAIL=ddelaunay@doubledtech.fr

# --- Astuce OVH ---------------------------------------------
# SMTP_PASS = le mot de passe de la boîte ddelaunay@doubledtech.fr
# (celui utilisé pour vous connecter au webmail OVH / configurer Outlook).
# Si vous l'avez oublié : Espace client OVH > Emails > la boîte >
# "Modifier le mot de passe", puis collez le nouveau ici.
# Alternative : port 587 avec SMTP_SECURE=false (STARTTLS).
# ------------------------------------------------------------
