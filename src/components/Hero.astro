---
// Hero — animated DD badge, headline, tagline, CTAs
---

<section
  id="accueil"
  style="min-height:100vh; display:flex; flex-direction:column; align-items:center; justify-content:center; text-align:center; padding:140px 22px 90px; position:relative;"
>
  <div style="position:relative; margin-bottom:48px; animation:ddfloat 6s ease-in-out infinite;">
    <div
      style="position:absolute; inset:-42px; border-radius:50%; background:radial-gradient(circle, rgba(0,230,118,.38), transparent 68%); filter:blur(14px); animation:ddpulse 4.5s ease-in-out infinite;"
    >
    </div>
    <div
      style="position:absolute; inset:-10px; border-radius:50%; border:2px solid rgba(0,230,118,.35); border-top-color:#00e676; border-right-color:transparent; animation:ddring 9s linear infinite;"
    >
    </div>
    <div
      style="position:relative; width:178px; height:178px; border-radius:50%; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:6px; background:radial-gradient(circle at 50% 32%, rgba(9,32,52,.95), rgba(4,14,24,.98)); border:2px solid #00e676; box-shadow:0 0 42px rgba(0,230,118,.55), inset 0 0 30px rgba(0,230,118,.14);"
    >
      <div
        style="font-family:'Space Grotesk'; font-weight:700; font-size:60px; letter-spacing:-4px; color:#00e676; text-shadow:0 0 22px rgba(0,230,118,.85); line-height:1;"
      >
        DD
      </div>
      <div style="font-family:'JetBrains Mono'; font-size:9px; letter-spacing:3.5px; color:#9fe6c2;">
        DOUBLE D TECH
      </div>
    </div>
  </div>

  <h1
    class="dd-hero-h1"
    style="margin:0; font-size:clamp(48px, 8vw, 104px); font-weight:700; letter-spacing:-2px; line-height:.98; color:#f4faf8; text-shadow:0 0 40px rgba(0,230,118,.18);"
  >
    Double D Tech
  </h1>

  <div
    style="display:inline-flex; align-items:center; gap:0; flex-wrap:wrap; justify-content:center; margin-top:26px; padding:8px 20px; border-radius:999px; border:1px solid rgba(0,230,118,.28); background:rgba(6,24,38,.5); font-family:'JetBrains Mono'; font-size:12px; letter-spacing:1px; color:#8fe9bd;"
  >
    Cybersécurité<span style="color:#00e676; margin:0 10px;">•</span>Audit<span
      style="color:#00e676; margin:0 10px;">•</span
    >Analyse de risque<span style="color:#00e676; margin:0 10px;">•</span>Veille
  </div>

  <div style="display:flex; flex-wrap:wrap; gap:16px; justify-content:center; margin-top:40px;">
    <a
      class="dd-btn dd-primary"
      href="#contact"
      style="padding:15px 30px; border-radius:999px; background:#00e676; color:#04140b; font-weight:700; font-size:15px; box-shadow:0 0 24px rgba(0,230,118,.4);"
      >Demander un diagnostic</a
    >
    <a
      class="dd-btn dd-ghost"
      href="#services"
      style="padding:15px 30px; border-radius:999px; border:1px solid rgba(0,230,118,.55); color:#eafff4; font-weight:600; font-size:15px;"
      >Découvrir mes services</a
    >
  </div>

  <div
    style="position:absolute; bottom:34px; left:50%; transform:translateX(-50%); width:26px; height:42px; border-radius:16px; border:1.5px solid rgba(0,230,118,.5); display:flex; justify-content:center; padding-top:8px;"
  >
    <div
      style="width:4px; height:8px; border-radius:2px; background:#00e676; box-shadow:0 0 8px #00e676; animation:ddscrolldot 1.8s ease-in-out infinite;"
    >
    </div>
  </div>
</section>
